{
  "manifest_version": 3,
  "name": "YouTube Tab Fullscreen",
  "version": "1.0.0",
  "description": "Makes YouTube videos fullscreen within the tab instead of OS fullscreen. Press ` (backtick) to toggle.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
